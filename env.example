# Copy this to .env for local testing (never commit .env)

ANTHROPIC_API_KEY=your_anthropic_key_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX      # the number Twilio gave you
YOUR_PHONE_NUMBER=+1XXXXXXXXXX        # your real phone number

APP_URL=https://your-railway-app.up.railway.app   # update after deploying

# Optional: change wake time (24hr, ET)
WAKE_HOUR=7
WAKE_MINUTE=0
